# OpsFlow Environment Variables
# Copy this to .env and fill in your values — never commit .env to version control

# PostgreSQL
POSTGRES_USER=opsflow
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=opsflow

# Constructed from the above when running locally outside Docker:
DATABASE_URL=postgresql://opsflow:your_secure_password_here@localhost:5432/opsflow

# Auth
JWT_SECRET=your_jwt_secret_here

# Server
PORT=5001
